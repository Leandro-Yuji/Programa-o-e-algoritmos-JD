programa {
  funcao inicio() {
  real numero
  real numero2
  real numero3
  real numero4
  inteiro media

  escreva(" informe suas notas: ")
  leia(numero)
  leia(numero2)
  leia(numero3)
  leia(numero4)
  inteiro media = (numero + numero2 + numero3 + numero4) / 4

  escreva("sua média é: ",(media) )

  }
}
