programa {
  funcao inicio() {
   cadeia compra inteiro valor,parcela
    escreva("Informe sua compra:")
    leia(compra)
    escreva("o valor da sua compra é:")
    leia(valor)
    escreva("Quantas parcelas você deseja:")
    leia(parcela)
    escreva("o valor da prestação é:",valor/parcela)

  }
}
